# Hospital Readmission Risk Predictor — Environment Configuration
# Copy this file to .env and adjust values for your environment.

# ──────────────────────────────────────────────
# Paths
# ──────────────────────────────────────────────
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
OUTPUT_DIR=outputs
MODEL_DIR=.

# ──────────────────────────────────────────────
# Reproducibility
# ──────────────────────────────────────────────
RANDOM_SEED=42

# ──────────────────────────────────────────────
# Training
# ──────────────────────────────────────────────
TEST_SIZE=0.2
CV_FOLDS=5
N_ITER_SEARCH=50

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=INFO
